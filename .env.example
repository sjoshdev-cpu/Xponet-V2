# Copy this file to .env.local for local dev, or .env.production on the VM.
# All VITE_ variables are embedded into the JS bundle at build time — never put secrets here.

# ── Firebase ─────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Cloud name visible on Cloudinary dashboard → Settings → Account
VITE_CLOUDINARY_CLOUD_NAME=
# Unsigned upload preset name (created under Settings → Upload presets)
# Recommended restrictions: max 10 MB, allowed formats jpg/png/pdf/mp4, single folder
VITE_CLOUDINARY_UPLOAD_PRESET=

# ── Sentry ────────────────────────────────────────────────────────────────────
# DSN from Sentry → Project → Settings → Client Keys
VITE_SENTRY_DSN=
