{
  "name": "Database",
  "type": "object",
  "properties": {
    "name":        { "type": "string" },
    "icon":        { "type": "string", "description": "Emoji or URL for the database icon" },
    "description": { "type": "string" },
    "schema": {
      "type": "array",
      "description": "Ordered list of property column definitions",
      "items": {
        "type": "object",
        "properties": {
          "key":  { "type": "string", "description": "Unique identifier for this property" },
          "name": { "type": "string", "description": "Display label" },
          "type": {
            "type": "string",
            "enum": ["title", "text", "number", "select", "multi_select", "date", "people", "checkbox", "url", "email", "phone", "created_time", "created_by", "last_edited_time", "last_edited_by"]
          }
        },
        "required": ["key", "name", "type"]
      }
    },
    "org_id": { "type": "string" }
  },
  "required": ["name", "org_id"]
}
