{
  "name": "Record",
  "type": "object",
  "properties": {
    "database_id":          { "type": "string", "description": "ID of the parent Database" },
    "page_id":              { "type": "string", "description": "ID of the linked Page (each record has a backing page)" },
    "properties":           { "type": "object", "description": "Map of propertyKey → value, matching the parent database schema" },
    "created_by_email":     { "type": "string" },
    "created_by_name":      { "type": "string" },
    "last_edited_by_email": { "type": "string" },
    "last_edited_by_name":  { "type": "string" },
    "org_id":               { "type": "string" }
  },
  "required": ["database_id", "page_id", "org_id"]
}
