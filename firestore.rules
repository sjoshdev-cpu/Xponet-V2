rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function myEmail() {
      return request.auth.token.email;
    }

    // Check that the calling user is a member of an org (single Firestore get)
    function isOrgMember(orgId) {
      return isAuthed()
          && myEmail() in get(/databases/$(database)/documents/organizations/$(orgId)).data.memberEmails;
    }

    // The calling user's role within an org ('admin' | 'supervisor' | 'member' | null)
    function myRole(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data.memberRoles[myEmail()];
    }

    function isAdminOrSupervisor(orgId) {
      return myRole(orgId) in ['admin', 'supervisor'];
    }

    // Page permission helpers that operate on a document data map
    function pageHasNoPerms(data) {
      return !('permissions' in data) || data.permissions.size() == 0;
    }

    function isPageOwner(data) {
      return data.permissions.hasAny([{ 'email': myEmail(), 'role': 'owner' }]);
    }

    function isPageEditor(data) {
      return data.permissions.hasAny([
        { 'email': myEmail(), 'role': 'owner' },
        { 'email': myEmail(), 'role': 'editor' }
      ]);
    }

    // Prevent non-owners from modifying the permissions array
    function notEscalatingPerms(existingData) {
      return !('permissions' in request.resource.data)
          || request.resource.data.permissions == existingData.permissions
          || isPageOwner(existingData);
    }

    // Public shared page that hasn't expired
    function isPubliclyShared(data) {
      return data.is_shared == true
          && (!('share_expires_at' in data)
              || data.share_expires_at == null
              || request.time < data.share_expires_at);
    }

    // Minimal structural validation
    function hasString(data, field) {
      return field in data && data[field] is string && data[field].size() > 0;
    }

    // ─── Organizations ───────────────────────────────────────────────────────

    // Is the calling user on an org document's pending-invite list?
    function isPendingInvitee(data) {
      return myEmail() in data.get('pendingInviteEmails', []);
    }

    // Invite acceptance/decline: the pending lists must shrink by exactly the
    // caller — nobody else's invite may be touched.
    function removesOnlySelfFromPending(existingData, newData) {
      return isPendingInvitee(existingData)
          && !(myEmail() in newData.get('pendingInviteEmails', []))
          && existingData.pendingInviteEmails.hasAll(newData.get('pendingInviteEmails', []))
          && newData.get('pendingInviteEmails', []).size() == existingData.pendingInviteEmails.size() - 1;
    }

    // Accept: membership grows by exactly the caller, at exactly the role
    // they were invited with (no self-escalation to admin).
    function addsOnlySelfAsMember(existingData, newData) {
      return !(myEmail() in existingData.memberEmails)
          && myEmail() in newData.memberEmails
          && newData.memberEmails.hasAll(existingData.memberEmails)
          && newData.memberEmails.size() == existingData.memberEmails.size() + 1
          && newData.memberRoles[myEmail()] == existingData.pendingInviteRoles[myEmail()];
    }

    match /organizations/{orgId} {
      // Members may read their own org; pending invitees may read it too so
      // the app can show them the invitation to accept or decline.
      // (Direct field access — not .get() — so list queries filtered with
      // array-contains on either field are statically provable.)
      allow read: if isAuthed()
          && (myEmail() in resource.data.memberEmails
              || myEmail() in resource.data.pendingInviteEmails);

      // Anyone authenticated can create an org (registration flow)
      allow create: if isAuthed();

      // Members may update; they cannot remove themselves from memberEmails
      // to prevent accidental self-lock-out (but not a hard security requirement)
      allow update: if isAuthed()
          && myEmail() in resource.data.memberEmails
          && myEmail() in request.resource.data.memberEmails;

      // A pending invitee may update the org ONLY to resolve their own invite:
      // decline (membership unchanged) or accept (adds exactly themselves at
      // the invited role). The owner never changes.
      allow update: if isAuthed()
          && removesOnlySelfFromPending(resource.data, request.resource.data)
          && request.resource.data.owner_email == resource.data.owner_email
          && (request.resource.data.memberEmails == resource.data.memberEmails
              || addsOnlySelfAsMember(resource.data, request.resource.data));

      // Orgs are never deleted from the client
      allow delete: if false;
    }

    // ─── Pages ──────────────────────────────────────────────────────────────

    match /pages/{pageId} {
      // Public share links (unauthenticated or authenticated)
      allow read: if isPubliclyShared(resource.data);

      // Org members may read pages belonging to their org
      allow read: if isAuthed() && isOrgMember(resource.data.org_id);

      // Create: must be org member; org_id must be supplied
      allow create: if isAuthed()
          && hasString(request.resource.data, 'org_id')
          && isOrgMember(request.resource.data.org_id);

      // Update: org member + is owner/editor (or no explicit perms) + cannot
      //         escalate permissions beyond current role
      allow update: if isAuthed()
          && isOrgMember(resource.data.org_id)
          && (pageHasNoPerms(resource.data) || isPageEditor(resource.data))
          && notEscalatingPerms(resource.data);

      // Delete (soft or hard): org member + owner (or no perms set)
      allow delete: if isAuthed()
          && isOrgMember(resource.data.org_id)
          && (pageHasNoPerms(resource.data) || isPageOwner(resource.data));
    }

    // "What links to this page" — one doc per source page that references it.
    // Org membership is resolved through the parent page's own org_id since
    // these subcollection docs don't carry org_id themselves.
    match /pages/{pageId}/backlinks/{sourcePageId} {
      allow read, write: if isAuthed()
          && isOrgMember(get(/databases/$(database)/documents/pages/$(pageId)).data.org_id);
    }

    // ─── Tasks ──────────────────────────────────────────────────────────────

    match /tasks/{taskId} {
      // Admins/supervisors see every task in the org; everyone else only
      // sees tasks they're an assignee on. Client queries for non-privileged
      // roles must filter with where('assignee_emails','array-contains', email)
      // to match this — an unfiltered query will be rejected outright.
      allow read: if isAuthed() && isOrgMember(resource.data.org_id)
          && (isAdminOrSupervisor(resource.data.org_id)
              || myEmail() in resource.data.get('assignee_emails', []));
      allow create: if isAuthed()
          && hasString(request.resource.data, 'org_id')
          && hasString(request.resource.data, 'title')
          && isOrgMember(request.resource.data.org_id);
      allow update: if isAuthed() && isOrgMember(resource.data.org_id);
      allow delete: if isAuthed() && isOrgMember(resource.data.org_id);
    }

    // ─── User profiles (personal, not org-scoped) ──────────────────────────
    // Pinned/recent pages etc. Doc id == the user's own Firebase Auth uid.

    match /user_profiles/{uid} {
      allow read, write: if isAuthed() && request.auth.uid == uid;
    }

    // ─── Reminder configs ───────────────────────────────────────────────────
    // One doc per org (doc id == org_id). Any org member can read the current
    // settings; only admins can change them.

    match /reminder_configs/{orgId} {
      allow read:  if isOrgMember(orgId);
      allow write: if isOrgMember(orgId) && myRole(orgId) == 'admin';
    }

    // ─── Mail queue ─────────────────────────────────────────────────────────
    // Outbound email queue. Org members may ENQUEUE messages (e.g. workspace
    // invitations); the scheduled GitHub Action drains the queue with the
    // Admin SDK (which bypasses these rules). Clients can never read, edit,
    // or delete queued mail — so the queue can't be used to snoop addresses
    // or forge/alter someone else's pending messages.

    match /mail/{mailId} {
      allow create: if isAuthed()
          && hasString(request.resource.data, 'org_id')
          && isOrgMember(request.resource.data.org_id)
          && hasString(request.resource.data, 'to')
          && hasString(request.resource.data, 'subject')
          && hasString(request.resource.data, 'text');
      allow read, update, delete: if false;
    }

    // ─── Tickets ────────────────────────────────────────────────────────────

    match /tickets/{ticketId} {
      allow read:   if isAuthed() && isOrgMember(resource.data.org_id);
      allow create: if isAuthed()
          && hasString(request.resource.data, 'org_id')
          && hasString(request.resource.data, 'title')
          && isOrgMember(request.resource.data.org_id);
      allow update: if isAuthed() && isOrgMember(resource.data.org_id);
      allow delete: if isAuthed() && isOrgMember(resource.data.org_id);
    }

    // ─── Comments ───────────────────────────────────────────────────────────

    match /comments/{commentId} {
      allow read:   if isAuthed() && isOrgMember(resource.data.org_id);
      allow create: if isAuthed()
          && hasString(request.resource.data, 'org_id')
          && isOrgMember(request.resource.data.org_id);
      // Only the author may edit their own comment
      allow update: if isAuthed()
          && isOrgMember(resource.data.org_id)
          && resource.data.author_email == myEmail();
      allow delete: if isAuthed()
          && isOrgMember(resource.data.org_id)
          && resource.data.author_email == myEmail();
    }

    // ─── Notifications ──────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      // Only the recipient may read/update/delete their own notifications
      allow read:   if isAuthed() && resource.data.recipient_email == myEmail();
      allow create: if isAuthed()
          && hasString(request.resource.data, 'org_id')
          && isOrgMember(request.resource.data.org_id);
      allow update: if isAuthed() && resource.data.recipient_email == myEmail();
      allow delete: if isAuthed() && resource.data.recipient_email == myEmail();
    }

    // ─── Databases / Records / Views ────────────────────────────────────────

    match /databases/{dbId} {
      allow read:   if isAuthed() && isOrgMember(resource.data.org_id);
      allow create: if isAuthed()
          && hasString(request.resource.data, 'org_id')
          && isOrgMember(request.resource.data.org_id);
      allow update: if isAuthed() && isOrgMember(resource.data.org_id);
      allow delete: if isAuthed() && isOrgMember(resource.data.org_id);
    }

    match /records/{recordId} {
      allow read:   if isAuthed() && isOrgMember(resource.data.org_id);
      allow create: if isAuthed()
          && hasString(request.resource.data, 'org_id')
          && isOrgMember(request.resource.data.org_id);
      allow update: if isAuthed() && isOrgMember(resource.data.org_id);
      allow delete: if isAuthed() && isOrgMember(resource.data.org_id);
    }

    match /db_views/{viewId} {
      allow read:   if isAuthed() && isOrgMember(resource.data.org_id);
      allow create: if isAuthed()
          && hasString(request.resource.data, 'org_id')
          && isOrgMember(request.resource.data.org_id);
      allow update: if isAuthed() && isOrgMember(resource.data.org_id);
      allow delete: if isAuthed() && isOrgMember(resource.data.org_id);
    }

    match /db_row_templates/{templateId} {
      allow read:   if isAuthed() && isOrgMember(resource.data.org_id);
      allow create: if isAuthed()
          && hasString(request.resource.data, 'database_id')
          && isOrgMember(request.resource.data.org_id);
      allow update: if isAuthed() && isOrgMember(resource.data.org_id);
      allow delete: if isAuthed() && isOrgMember(resource.data.org_id);
    }

    // ─── Presence (ephemeral) ───────────────────────────────────────────────

    match /presence/{pageId}/viewers/{userId} {
      allow read:  if isAuthed();
      allow write: if isAuthed() && request.auth.uid == userId;
    }
  }
}
