# Copy to server/.env and fill in. Never commit .env or the service-account key.

# Gemini API key — https://aistudio.google.com/apikey (free tier, no card)
GEMINI_API_KEY=

# Path to the Firebase service-account JSON (relative to server/).
# Generate: Firebase Console -> Project Settings -> Service accounts ->
# Generate new private key. Save it as server/serviceAccountKey.json.
SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Firestore database id — the app uses the named 'xponet' database.
FIRESTORE_DATABASE_ID=xponet

# gemini-2.5-flash (default) or gemini-2.5-flash-lite (cheaper/faster)
AGENT_MODEL=gemini-2.5-flash

# Port the agent server listens on (Vite + nginx proxy /api here).
PORT=8787

# CORS: leave unset to reflect the request origin (fine behind a proxy).
# Set to your site origin if you ever call the server cross-origin directly.
# ALLOWED_ORIGIN=https://yourdomain.com
